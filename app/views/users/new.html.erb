<% provide(:title, "Sign up")%>
<h1> Sigh up </h1>

<div class = "row">
    <div class = "col-md-6 col-md-offset-3">
        <%= form_with(model: @user) do |f| %>
            <%= render "shared/error_messages"%> <%#shared: いろんなviewの部品をおく．%>
            <%#=sharedのなかのerror_messagesを出力してねの意味%>
            <%= f.label :name %>
            <%= f.text_field :name, class:"form-control"%> <%#=入力欄%>

            <%= f.label :email %>
            <%= f.email_field :email,class:"form-control"%>
        
            <%= f.label :password %>
            <%= f.password_field :password,class:"form-control"%>

            <%= f.label :password_confirmation,"Confirmation" %>
            <%= f.password_field :password_confirmatio,class:"form-control" %>

            <%= f.submit "Create my account",  class: "btn btn-primary" %>
        <%end%>
    </div>
</div>
